# ── Firebase — usa el MISMO proyecto que la app Vista360 (ERP) ──
# Copia estos valores tal cual los tienes en el .env.local de Vista360,
# así el Player lee los paneles/contenido del mismo Firestore.
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123:web:abc

# Versión mostrada internamente (opcional)
VITE_APP_VERSION=0.1.0

# ── Cloudinary — solo lo usa la cuenta ADMIN para subir evidencias ──
# Copia los mismos valores que usa Vista360 (son públicos, no son secretos).
# Si los dejas vacíos, la app funciona igual para clientes — solo el botón
# de "Subir evidencia" del admin va a fallar con un mensaje claro.
VITE_CLOUDINARY_CLOUD_NAME=tu-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=tu-preset-sin-firmar
